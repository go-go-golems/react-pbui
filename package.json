{
  "name": "pbui-monorepo",
  "private": true,
  "version": "0.1.0",
  "description": "Presentation-based UI (CLIM/Genera Dynamic Windows style) packages for TypeScript + React",
  "scripts": {
    "test": "pnpm -r --if-present test",
    "typecheck": "pnpm -r --if-present typecheck",
    "demos": "pnpm --filter @go-go-golems/pbui-demos dev",
    "build:publish": "pnpm -r --filter './packages/*' run build:dist",
    "pack:smoke": "pnpm run build:publish && node scripts/packages/pack-smoke.mjs",
    "publish:npm": "node scripts/packages/publish-npm.mjs"
  },
  "devDependencies": {
    "typescript": "^5.5.4"
  }
}
